{% assign ai_product_name = 'Premium Requests' %}
{% comment %}After June 1, 2026, the name changes to 'GitHub AI Credits'{% endcomment %}
{%- assign _cur_year = 0 | days_ago | date: "%Y" | plus: 0 -%}
{%- assign _cur_month = 0 | days_ago | date: "%-m" | plus: 0 -%}
{%- if _cur_year > 2026 or _cur_year == 2026 and _cur_month >= 6 -%}
{% assign ai_product_name = 'GitHub AI Credits' %}
{%- endif -%}

{% assign date_string = IDX_1.timePeriod.year | append: '-' | append: IDX_1.timePeriod.month | append: '-01' %}
{% assign github_user = IDX_0 %}
{% assign current_month = IDX_1 %}
{% assign previous_month = IDX_2 %}

{% template usage_meter %}
{% assign consumed = 0 %}
{% assign overage = 0 %}
{% assign budget = trmnl.plugin_settings.custom_fields_values.github_premium_request_budget | default: 100 | plus: 0 %}
{% for usage in month_usage.usageItems %}
  {% assign consumed = consumed | plus: usage.grossQuantity %}
  {% assign overage = overage | plus: usage.netAmount %}
{% endfor %}
{% assign percent_consumed = consumed | divided_by: budget | times: 100 %}

<div class="progress-bar progress-bar--large w--full">
  <div class="content">
    <span class="label">{{ title }} ({{ consumed | round: 2 }} of {{ budget }})</span>
    <span class="value value--xxsmall">
      {{ percent_consumed | round: 2 }}%
    </span>
  </div>
  <div class="track">
    {% assign extra_fill = '' %}
    {% if percent_consumed > 75 %}{% assign extra_fill = 'bg--yellow' %}{% endif %}
    {% if percent_consumed > 90 %}{% assign extra_fill = 'bg--red' %}{% endif %}
    <div class="fill {{ extra_fill }}" style="width: {{ percent_consumed | plus: 1 }}%">
      {% if overage > 0 %}
      <span class="label label--base px--2 py--1 text-stroke text-stroke--medium">Overage: {{ overage | number_to_currency }}</span>
      {% endif %}</div>
  </div>
</div>
{% endtemplate %}

{% template detail_table %}
<table class="table table--xsmall lg:table--condensed" data-table-limit="true">
  <thead>
    <tr>
      <th><span class="title title--small lg:title--base">Model</span></th>
      <th><span class="title title--small lg:title--base">Price/Unit</span></th>
      <th><span class="title title--small lg:title--base">Quantity</span></th>
      <th><span class="title title--small lg:title--base">Amount</span></th>
      <th><span class="title title--small lg:title--base">Discount Qty.</span></th>
      <th><span class="title title--small lg:title--base">Discount</span></th>
      <th><span class="title title--small lg:title--base">Net Qty.</span></th>
      <th><span class="title title--small lg:title--base">Amount</span></th>
    </tr>
  </thead>
  <tbody>
    {% for usage in month_usage.usageItems %}
    <tr>
      <td class="text--left"><span class="label label--small lg:label--base" data-clamp="1">{{ usage.model }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.pricePerUnit | number_to_currency }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.grossQuantity | round: 1 }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.grossAmount | number_to_currency }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.discountQuantity | round: 1 }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.discountAmount | number_to_currency  }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.netQuantity | round: 1 }}</span></td>
      <td class="text--right"><span class="label label--small lg:label--base">{{ usage.netAmount | number_to_currency }}</span></td>
    </tr>
    {% else %}
    <tr>
      <td class="text--center py--10" colspan="99"><span class="title title--base">No data for given month.</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endtemplate %}
